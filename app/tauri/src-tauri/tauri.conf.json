{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ubuntu-aktualizacje",
  "mainBinaryName": "ubuntu-aktualizacje",
  "version": "0.1.0",
  "identifier": "io.github.mk.ubuntu-aktualizacje",
  "build": {
    "frontendDist": "../frontend-stub"
  },
  "app": {
    "windows": [
      {
        "title": "Ubuntu_Aktualizacje",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://127.0.0.1:8765/",
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "Utility",
    "shortDescription": "Local dashboard for Ubuntu update suite",
    "longDescription": "Native Tauri shell that wraps the FastAPI dashboard at http://127.0.0.1:8765/. Manages Ubuntu updates: APT, snap, brew, npm, pip, flatpak, drivers, plus snapshots, scheduler, and multi-host overview.",
    "linux": {
      "deb": {
        "depends": ["python3", "python3-venv", "ssh-client"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
