#!/usr/bin/env bash
# Stop user-services that may have been installed; never error out on absence.
set -e
for u in $(getent passwd | awk -F: '$3>=1000 && $3<60000 {print $1}'); do
    sudo -u "$u" XDG_RUNTIME_DIR="/run/user/$(id -u "$u")" \
        systemctl --user stop ubuntu-aktualizacje-dashboard.service 2>/dev/null || true
done
exit 0
