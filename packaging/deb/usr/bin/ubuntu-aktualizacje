#!/usr/bin/env bash
# Thin shim → dispatches to the right script under the project root.
# Subcommands:
#   (default)            → update-all.sh
#   fresh                → scripts/fresh-machine.sh
#   dashboard            → run dashboard ad-hoc (uses app/.venv if present)
#   schedule [args...]   → scripts/scheduler/install.sh
#   apps {detect|add|remove|list|install-missing} → scripts/apps/<sub>.sh
#   snapshot list|create|restore → scripts/snapshot/<sub>.sh
#
# ROOT resolution:
#   1. ASCENDO_ROOT env var (explicit override)
#   2. /opt/ubuntu-aktualizacje (deb-installed location)
#   3. directory containing this script + ../../../../ (repo bin/ascendo)
set -euo pipefail

if [[ -n "${ASCENDO_ROOT:-}" && -d "${ASCENDO_ROOT}" ]]; then
    ROOT="${ASCENDO_ROOT}"
elif [[ -d /opt/ubuntu-aktualizacje && -f /opt/ubuntu-aktualizacje/update-all.sh ]]; then
    ROOT=/opt/ubuntu-aktualizacje
else
    # Resolve symlink to find the real script, then walk up to repo root.
    SELF="$(readlink -f "$0")"
    # packaging/deb/usr/bin/ubuntu-aktualizacje  → repo root is 4 levels up
    ROOT="$(cd "$(dirname "$SELF")/../../../.." && pwd)"
fi
[[ -f "$ROOT/update-all.sh" ]] || { echo "ascendo: cannot locate project root (tried ASCENDO_ROOT, /opt/ubuntu-aktualizacje, repo)"; exit 2; }
case "${1:-}" in
    fresh)        shift; exec bash "$ROOT/scripts/fresh-machine.sh" "$@" ;;
    schedule)     shift; exec bash "$ROOT/scripts/scheduler/install.sh" "$@" ;;
    apps)         shift; case "${1:-list}" in
                      detect)          shift; exec bash "$ROOT/scripts/apps/detect.sh" "$@" ;;
                      add)             shift; exec bash "$ROOT/scripts/apps/add.sh" "$@" ;;
                      remove)          shift; exec bash "$ROOT/scripts/apps/remove.sh" "$@" ;;
                      list)            exec bash "$ROOT/scripts/apps/list.sh" ;;
                      install-missing) shift; exec bash "$ROOT/scripts/apps/install-missing.sh" "$@" ;;
                      *) echo "ascendo apps {detect|add|remove|list|install-missing}"; exit 2 ;;
                  esac ;;
    snapshot)     shift; case "${1:-list}" in
                      list)   exec bash "$ROOT/scripts/snapshot/list.sh" ;;
                      create) shift; exec bash "$ROOT/scripts/snapshot/create.sh" "$@" ;;
                      restore) shift; exec bash "$ROOT/scripts/snapshot/restore.sh" "$@" ;;
                  esac ;;
    settings)     shift; case "${1:-help}" in
                      export) shift
                              dest="${1:-ascendo-backup-$(date +%Y%m%d_%H%M%S).tar.gz}"
                              cd "$ROOT" && python3 -c "import sys; sys.path.insert(0,'.'); from app.backend import backup; sys.stdout.buffer.write(backup.export_bundle())" > "$dest"
                              echo "wrote ${dest} ($(stat -c%s "$dest") bytes)" ;;
                      import) shift
                              src="${1:-}"
                              [[ -f "$src" ]] || { echo "ascendo settings import <bundle.tar.gz>"; exit 2; }
                              cd "$ROOT" && python3 -c "import sys; sys.path.insert(0,'.'); from app.backend import backup; r=backup.import_bundle(open(sys.argv[1],'rb').read()); print('restored:', len(r['restored']), 'files')" "$src" ;;
                      *) echo "ascendo settings {export [file]|import <file>}"; exit 2 ;;
                  esac ;;
    health)       shift; exec bash "$ROOT/scripts/health-check.sh" "$@" ;;
    exclusions)   shift; case "${1:-list}" in
                      list) grep -v '^[[:space:]]*#' "$ROOT/config/exclusions.list" 2>/dev/null | grep -v '^[[:space:]]*$' || echo "(none)" ;;
                      add)  shift; pkg="${1:-}"; [[ -n "$pkg" ]] || { echo "ascendo exclusions add <cat:pkg>"; exit 2; }
                            grep -qx "$pkg" "$ROOT/config/exclusions.list" 2>/dev/null || echo "$pkg" >> "$ROOT/config/exclusions.list"
                            echo "+ $pkg" ;;
                      remove) shift; pkg="${1:-}"; [[ -n "$pkg" ]] || { echo "ascendo exclusions remove <cat:pkg>"; exit 2; }
                            tmp=$(mktemp); grep -vx "$pkg" "$ROOT/config/exclusions.list" > "$tmp" && mv "$tmp" "$ROOT/config/exclusions.list"
                            echo "- $pkg" ;;
                      *) echo "ascendo exclusions {list|add cat:pkg|remove cat:pkg}"; exit 2 ;;
                  esac ;;
    dashboard)
        if [[ -x "$ROOT/app/.venv/bin/python" ]]; then
            cd "$ROOT" && exec "$ROOT/app/.venv/bin/python" -m app.backend
        fi
        bash "$ROOT/app/install.sh" >&2
        cd "$ROOT" && exec "$ROOT/app/.venv/bin/python" -m app.backend ;;
    "" | --*) exec bash "$ROOT/update-all.sh" "$@" ;;
    *)        exec bash "$ROOT/update-all.sh" "$@" ;;
esac
