{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ubuntu-aktualizacje/schemas/phase-result.schema.json",
  "title": "Ubuntu_Aktualizacje phase result",
  "description": "Sidecar JSON emitted by every phase script (check|plan|apply|verify|cleanup).",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "category",
    "host",
    "started_at",
    "ended_at",
    "exit_code",
    "summary",
    "items",
    "diagnostics",
    "needs_reboot"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "ubuntu-aktualizacje/v1"
    },
    "kind": {
      "type": "string",
      "enum": ["check", "plan", "apply", "verify", "cleanup"]
    },
    "category": {
      "type": "string",
      "description": "Built-in category id, or 'plugin:<id>' for third-party plugins.",
      "pattern": "^(apt|snap|brew|npm|pip|flatpak|drivers|inventory|plugin:[a-z0-9][a-z0-9_-]{0,40})$"
    },
    "host": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "summary": {
      "type": "object",
      "required": ["ok", "warn", "err"],
      "additionalProperties": false,
      "properties": {
        "ok":   { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "err":  { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "result"],
        "additionalProperties": true,
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "action":      { "type": "string", "minLength": 1 },
          "from":        { "type": ["string", "null"] },
          "to":          { "type": ["string", "null"] },
          "result":      {
            "type": "string",
            "enum": ["ok", "warn", "skipped", "failed", "noop"]
          },
          "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
          "details":     { "type": ["string", "null"] }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "code", "msg"],
        "additionalProperties": false,
        "properties": {
          "level": { "type": "string", "enum": ["info", "warn", "error"] },
          "code":  { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{1,40}$" },
          "msg":   { "type": "string", "minLength": 1 }
        }
      }
    },
    "log_path":     { "type": ["string", "null"] },
    "needs_reboot": { "type": "boolean" },
    "advisory":     {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
