# =============================================================================
# config/pip-packages.list — Python packages to install via pip (user install)
#
# Format: <package-name>[==version]  [# description]
# Lines starting with # are comments. Blank lines are ignored.
#
# NOTE: Prefer pipx for standalone CLI tools (pipx isolates each tool).
#       Use pip here for libraries or tools used in scripts/notebooks.
#
# These are installed with: pip3 install --user <package>
# Using Homebrew Python: /home/linuxbrew/.linuxbrew/bin/python3
# =============================================================================

# ── Currently no pip packages tracked ────────────────────────────────────────
# Add packages here as needed. Examples:
# requests                      # HTTP library
# httpie                        # CLI HTTP client
# yt-dlp                        # YouTube downloader
