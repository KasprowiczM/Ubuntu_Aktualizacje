# =============================================================================
# config/hosts.toml — Multi-host registry (rename from hosts.toml.example)
#
# Each host represents a remote machine running Ubuntu_Aktualizacje. The
# dashboard's "Hosts" view queries them via SSH (read-only by default).
#
# SSH config best practice: define each host in ~/.ssh/config with a key,
# then reference it here by `ssh_alias`. This file does NOT store credentials.
# =============================================================================

[laptop-01]
display_name = "Workshop laptop"
ssh_alias    = "laptop01"          # ~/.ssh/config Host entry
repo_path    = "~/Dev_Env/Ubuntu_Aktualizacje"
description  = "Dell Latitude, dev workstation"

[server-01]
display_name = "Home server"
ssh_alias    = "homeserver"
repo_path    = "/opt/Ubuntu_Aktualizacje"
description  = "Headless server, scheduled updates"

# To activate, copy:
#   cp config/hosts.toml.example config/hosts.toml
# and edit. config/hosts.toml is gitignored by default.
