# =============================================================================
# config/pipx-packages.list — Python CLI tools to install via pipx
#
# Format: <package-name>[==version]  [# description]
# Lines starting with # are comments. Blank lines are ignored.
#
# pipx installs each tool in its own isolated virtualenv.
# Perfect for standalone CLI tools that shouldn't pollute the system Python.
#
# These are installed with: pipx install <package>
# =============================================================================

# ── Currently no pipx packages tracked ───────────────────────────────────────
# Add tools here as needed. Examples:
# black                         # Python code formatter
# ruff                          # Fast Python linter
# poetry                        # Python dependency manager
# ansible                       # IT automation
# tldr                          # Simplified man pages
