# =============================================================================
# .gitignore — Ubuntu_Aktualizacje
# =============================================================================

# ── Machine-specific inventory (generated per-machine, never committed) ───────
APPS.md

# ── Runtime logs ──────────────────────────────────────────────────────────────
logs/*.log
logs/runs/

# ── Dashboard runtime ─────────────────────────────────────────────────────────
app/tauri/src-tauri/target/
app/tauri/src-tauri/Cargo.lock
app/tauri/src-tauri/icons/

# ── SQLite (per-user dashboard history) ──────────────────────────────────────
*.db
*.db-wal
*.db-shm

# ── Config backups created by --discover mode ─────────────────────────────────
config/*.bak_*

# ── Dev sync private overlay runtime state ────────────────────────────────────
.dev_sync_config.json
.dev_sync_manifest.json
dev_sync_logs/
dev_sync_quarantine/
dev_sync_cleanup_plan*.json
.sync-state/
config/dev-sync-*.local
*.rclone.conf

# ── Agent runtime caches ──────────────────────────────────────────────────────
.codex.local/tmp/
__pycache__/
*.py[cod]

# ── Graphify runtime internals (final report/html/json may be tracked) ────────
graphify-out/cache/
graphify-out/converted/
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/.graphify_*

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~
.idea/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code internal settings (machine-local) ─────────────────────────────
.claude/

.env*

# SSH keys
github
github.pub
app/.venv/
config/hosts.toml
