# =============================================================================
# config/apt-packages.list — APT packages to install and keep updated
#
# Format:  <package-name>  [# description]
# Lines starting with # are comments. Blank lines are ignored.
#
# Groups are indicated by section headers (comments only — for readability).
# =============================================================================

# ── Browsers ──────────────────────────────────────────────────────────────────
brave-browser               # Brave Browser (from brave-browser-release.sources)
google-chrome-stable        # Google Chrome (from google-chrome.list)

# ── Development Tools ─────────────────────────────────────────────────────────
code                        # VS Code (from vscode.sources)
antigravity                 # Antigravity desktop app (from antigravity repo)
git                         # Git version control
build-essential             # gcc, make, etc.
curl                        # HTTP client
wget                        # HTTP downloader
unzip                       # ZIP extractor
zip                         # ZIP compressor

# ── Docker ────────────────────────────────────────────────────────────────────
docker-ce                   # Docker Engine
docker-ce-cli               # Docker CLI
containerd.io               # containerd runtime
docker-buildx-plugin        # Docker Buildx
docker-compose-plugin       # Docker Compose v2

# ── NVIDIA (GPU/ML) ───────────────────────────────────────────────────────────
# nvidia-container-toolkit  # Optional: NVIDIA Container Toolkit for Docker GPU access
#                           # Install manually: sudo apt install nvidia-container-toolkit
# nvidia-driver-580         # Uncomment if NVIDIA GPU present (managed via update-drivers.sh)

# ── Cloud & Sync ──────────────────────────────────────────────────────────────
megasync                    # MEGA cloud sync (from meganz.list)
rclone                      # Multi-cloud sync CLI

# ── VPN & Privacy ─────────────────────────────────────────────────────────────
proton-vpn-gnome-desktop    # ProtonVPN desktop (includes daemon + gtk app)
proton-mail                 # Proton Mail desktop client

# ── Remote Access ─────────────────────────────────────────────────────────────
remotedesktopmanager        # Devolutions Remote Desktop Manager
remmina                     # Open-source remote desktop client

# ── System Tools ──────────────────────────────────────────────────────────────
grub-customizer             # Grub Customizer GUI (from PPA)
mc                          # Midnight Commander (file manager)
bleachbit                   # System cleaner
