# =============================================================================
# config/brew-formulas.list — Homebrew formulas to install and keep updated
#
# Format: <formula-name>  [# description]
# Lines starting with # are comments. Blank lines are ignored.
#
# Note: dependency-only formulas (e.g. openssl@3, readline) are intentionally
# NOT listed here — brew manages them automatically as deps. Only list formulas
# you explicitly want tracked and updated.
# =============================================================================

# ── AI / LLM CLI Tools ────────────────────────────────────────────────────────
gemini-cli                  # Google Gemini AI CLI
opencode                    # OpenCode AI coding agent
qwen-code                   # Qwen AI coding tool

# ── Runtime: Node.js ──────────────────────────────────────────────────────────
node                        # Node.js LTS (replaces system apt nodejs 18.x)

# ── Runtime: Python ───────────────────────────────────────────────────────────
python@3.14                 # Python 3.14 (latest stable)

# ── Compilers ─────────────────────────────────────────────────────────────────
gcc                         # GNU Compiler Collection

# ── Search & CLI Utilities ────────────────────────────────────────────────────
ripgrep                     # Fast grep replacement (used by editors/tools)
