# =============================================================================
# config/apt-repos.list — Third-party APT repositories to add
#
# One repo ID per line. Each ID maps to a setup function in lib/repos.sh.
# Format: <repo_id>  [# comment]
#
# To add a new repo:
#   1. Add the ID here
#   2. Add a corresponding _setup_repo_<id>() function in lib/repos.sh
# =============================================================================

brave                       # Brave Browser
chrome                      # Google Chrome
vscode                      # VS Code (Microsoft)
docker                      # Docker CE
# nvidia-container-toolkit  # optional (install manually only when Docker GPU is needed)
megasync                    # MEGA cloud sync client
protonvpn                   # ProtonVPN + Proton Mail
antigravity                 # Antigravity desktop app
grub-customizer-ppa         # Grub Customizer (PPA)
