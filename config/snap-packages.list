# =============================================================================
# config/snap-packages.list — Snap packages to install and keep updated
#
# Format: <snap-name> [--flags]  [# description]
#
# Supported flags:
#   --classic   Install in classic confinement (e.g. code, helm)
#   --edge      Use edge channel instead of stable
#   --beta      Use beta channel
#   --devmode   Developer mode (unconfined)
#
# Lines starting with # are comments. Blank lines are ignored.
# =============================================================================

# ── Browsers ──────────────────────────────────────────────────────────────────
firefox                     # Mozilla Firefox

# ── Email ─────────────────────────────────────────────────────────────────────
thunderbird                 # Mozilla Thunderbird email client

# ── Security ──────────────────────────────────────────────────────────────────
keepassxc                   # KeePassXC password manager

# ── System Utilities ──────────────────────────────────────────────────────────
htop                        # Interactive process viewer
firmware-updater            # GNOME firmware updater
snap-store
