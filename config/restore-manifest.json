{
  "format": 1,
  "project": "Ubuntu_Aktualizacje",
  "tracked_source_of_truth": "git",
  "private_overlay_source_of_truth": "dev-sync provider",
  "expected_private_overlay": [
    {
      "path": ".dev_sync_config.json",
      "class": "provider-config",
      "required_for": "dev-sync provider access",
      "restore": "manual/provider_setup"
    },
    {
      "path": ".env.local",
      "class": "secret-env",
      "required_for": "GitHub token helper and local-only credentials",
      "restore": "dev-sync"
    },
    {
      "path": "github",
      "class": "ssh-key",
      "required_for": "GitHub SSH auth on this host",
      "restore": "dev-sync"
    },
    {
      "path": "github.pub",
      "class": "ssh-public-key",
      "required_for": "GitHub SSH auth audit",
      "restore": "dev-sync"
    },
    {
      "path": ".claude/settings.local.json",
      "class": "agent-local-config",
      "required_for": "local agent preferences",
      "restore": "dev-sync"
    }
  ],
  "rebuildable_or_generated": [
    "APPS.md",
    "logs/",
    "dev_sync_logs/",
    "dev_sync_quarantine/",
    "config/*.bak_*",
    ".codex.local/tmp/",
    "__pycache__/",
    "node_modules/",
    "graphify-out/cache/"
  ],
  "fresh_clone_flow": [
    "bash scripts/preflight.sh",
    "bash dev-sync/provider_setup.sh",
    "bash scripts/restore-from-proton.sh --dry-run",
    "bash scripts/restore-from-proton.sh",
    "bash scripts/bootstrap.sh --skip-sync",
    "bash scripts/verify-state.sh"
  ]
}
